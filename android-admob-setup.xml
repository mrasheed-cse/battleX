<!--
═══════════════════════════════════════════════════════════════════════════════
  BattleX — AndroidManifest.xml AdMob Setup
  
  After running: npm run build:android
  
  Open file:
    android/app/src/main/AndroidManifest.xml
  
  Find the <application> tag and add this INSIDE it:
═══════════════════════════════════════════════════════════════════════════════
-->

<!-- PASTE THIS INSIDE <application> tag in AndroidManifest.xml -->
<meta-data
    android:name="com.google.android.gms.ads.APPLICATION_ID"
    android:value="ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX"/>
<!-- Replace ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX with your real AdMob App ID -->
<!-- Get it from: https://admob.google.com → Apps → your app → App settings -->

