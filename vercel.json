{
  "rewrites": [
    { "source": "/api/backend/:path*",       "destination": "/api/backend?path=:path*" },
    { "source": "/api/ludo-leaderboard",     "destination": "/api/ludo-leaderboard" },
    { "source": "/games/ludo/assets/(.*)",   "destination": "/games/ludo/assets/$1" },
    { "source": "/games/ludo/index.html",    "destination": "/games/ludo/index.html" },
    { "source": "/((?!api|games/ludo/assets|games/ludo/index.html).*)", "destination": "/index.html" }
  ]
}
